# ETF ChatBI 助手 - 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# Tushare API Token (用于获取ETF数据)
# 从 https://tushare.pro/ 注册获取
TRUSHARE_API_KEY=your_tushare_token_here

# DashScope API Key (用于qwen-agent的LLM功能)
# 从 https://dashscope.aliyun.com/ 获取
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# 邮件配置 (用于价格波动提醒)
# SMTP服务器地址 (QQ邮箱: smtp.qq.com, 163邮箱: smtp.163.com)
EMAIL_SMTP_SERVER=smtp.qq.com

# SMTP服务器端口 (SSL: 465, TLS: 587)
EMAIL_SMTP_PORT=465

# 发件人邮箱地址
EMAIL_SENDER=your_email@qq.com

# 邮箱授权码或密码 (建议使用授权码)
EMAIL_PASSWORD=your_email_password_or_auth_code

# 收件人邮箱地址 (多个邮箱用逗号分隔)
EMAIL_RECEIVER=receiver1@email.com,receiver2@email.com
